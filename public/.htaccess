# ===== DELHI METRO GUIDE - APACHE CONFIGURATION =====
# This .htaccess file handles URL rewriting for React Router and sets security headers

# Enable Rewrite Engine for single-page app routing
RewriteEngine On
RewriteBase /

# Preserve direct access to files and folders (don't rewrite real files/directories)
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# Route all other requests to index.html for React Router to handle
RewriteRule . /index.html [L]

# ===== SECURITY HEADERS =====
# These headers improve site security and provide positive SEO signals to Google
<IfModule mod_headers.c>
  # Prevent clickjacking attacks - only allow site to be embedded in iframes on same origin
  Header always set X-Frame-Options "SAMEORIGIN"
  
  # Prevent MIME type sniffing - browsers must respect Content-Type header
  Header always set X-Content-Type-Options "nosniff"
  
  # Enable XSS (Cross-Site Scripting) protection in older browsers
  Header always set X-XSS-Protection "1; mode=block"
  
  # Control referrer information sent to other sites (privacy & SEO signal)
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  
  # Enable DNS prefetch control
  Header set X-DNS-Prefetch-Control "on"
  
  # Permissions policy for features like camera, microphone
  Header set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=()"
  
  # Content Security Policy - allows from same origin
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src 'self' fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none';"
</IfModule>

# ===== COMPRESSION =====
# Enable GZIP compression for faster delivery and better Core Web Vitals scores
<IfModule mod_deflate.c>
  # Compress HTML, CSS, JavaScript and JSON responses
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# ===== CACHE HEADERS =====
# Set appropriate expiration times to reduce server load and improve performance
# Versioned assets (with hash) can be cached longer
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Default cache: 1 day
  ExpiresDefault "access plus 1 day"
  
  # Images - Cache for 1 year (icons, logos, etc.)
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # JavaScript - Cache for 30 days (versioned by build hash)
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType text/javascript "access plus 30 days"
  
  # CSS - Cache for 30 days (versioned by build hash)
  ExpiresByType text/css "access plus 30 days"
  
  # Fonts - Cache for 1 year (very stable)
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/x-font-ttf "access plus 1 year"
  ExpiresByType application/x-font-woff "access plus 1 year"
  
  # Media - Cache for 1 year
  ExpiresByType audio/mpeg "access plus 1 year"
  ExpiresByType audio/jpg "access plus 1 year"
  
  # Manifest and metadata - Cache for 7 days
  ExpiresByType application/manifest+json "access plus 7 days"
  ExpiresByType application/json "access plus 7 days"
  ExpiresByType text/xml "access plus 7 days"
  ExpiresByType application/xml "access plus 7 days"
  
  # HTML - Don't cache (always fetch latest)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ✅ CACHE CONTROL HEADERS - More aggressive caching
<FilesMatch "\.(js|css|woff|woff2|ttf|otf|eot|svg|png|jpg|jpeg|gif|webp|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# HTML files should not be cached
<FilesMatch "\.html$">
  Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>

# JSON files (sitemap, manifest)
<FilesMatch "\.json$">
  Header set Cache-Control "public, max-age=604800"
</FilesMatch>

# XML files (sitemap, robots)
<FilesMatch "\.xml$">
  Header set Cache-Control "public, max-age=604800"
</FilesMatch>

# ✅ E-TAG - Help browsers validate cached content
<IfModule mod_deflate.c>
  <IfModule mod_headers.c>
    Header append Vary Accept-Encoding
  </IfModule>
</IfModule>

# ✅ SECURITY HEADERS
<IfModule mod_headers.c>
  # Prevent MIME type sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # Enable XSS protection
  Header set X-XSS-Protection "1; mode=block"
  
  # Prevent clickjacking
  Header set X-Frame-Options "SAMEORIGIN"
  
  # Referrer Policy for privacy
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ✅ REMOVE HEADERS that reveal server info
<IfModule mod_headers.c>
  Header unset X-Powered-By
  Header unset Server
</IfModule>